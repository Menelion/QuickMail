<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Visible keyboard focus ring for all controls -->
    <Style x:Key="FocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Margin="2" StrokeThickness="2"
                               Stroke="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                               StrokeDashArray="2 1"
                               SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Apply focus visual globally -->
    <Style TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="MinHeight" Value="28"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <Style TargetType="TreeViewItem">
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
        <Setter Property="IsExpanded" Value="True"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <!-- Toolbar button style: Tab enters the toolbar from outside; Arrow keys navigate
         within it; Tab again exits.  Buttons are tab-stoppable so screen readers and
         keyboard users can reach them via standard Tab navigation. -->
    <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="MinWidth" Value="75"/>
        <Setter Property="Margin" Value="2,0"/>
    </Style>

    <!-- Toolbar toggle button (e.g. Conversation view) — same sizing as ToolbarButton. -->
    <Style x:Key="ToolbarToggleButton" TargetType="ToggleButton">
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
        <Setter Property="MinWidth" Value="75"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="MinHeight" Value="28"/>
    </Style>

    <!-- Status bar items — not focusable themselves; focus goes to the TextBox child. -->
    <Style TargetType="StatusBarItem">
        <Setter Property="Focusable" Value="False"/>
    </Style>

    <!-- Read-only TextBox used as the status bar text element.
         ControlType.Edit + ValuePattern means screen readers read its value
         natively when keyboard focus arrives (F6 pane cycling).
         Visually indistinguishable from a plain TextBlock, but focusable in UIA. -->
    <Style x:Key="StatusTextBoxStyle" TargetType="TextBox">
        <Setter Property="IsReadOnly"       Value="True"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="Cursor"           Value="Arrow"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
        <!-- Override the default TextBox chrome so it looks like a label -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
